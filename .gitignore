# Ignore Julia Manifest
Manifest.toml

# setuptools_scm auto-generates this file from the git tag
gallearn/_version.py

# ignore python compile files
*.pyc

# ignore backup files
*.bak

# ignore hidden files
.*
!.github

# ignore data folder
#data/*
*.h5
*.hdf5

# CI fixture HDF5s under tests/test_data/ are real test inputs, not
# generated data, so track them despite the blanket rule above.
!tests/test_data/**/*.h5
!tests/test_data/**/*.hdf5

# ignore compiled sysimages
*.so

# ignore slurm output
*.out
slurm.epilog-*

# astrophot writes this to the cwd unconditionally at import time
# (astrophot/config.py's logging.basicConfig), no way to opt out
AstroPhot.log

# ignore commit message scratch files
commit.txt

# ignore Claude instruction files
CLAUDE.md

__pycache__

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
